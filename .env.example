# ============================================================
# JusticePourtous — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs.
# NE JAMAIS committer le .env — il est dans .gitignore.
# Secrets de prod : Bitwarden Secrets Manager (bws), project studio-robin.
# ============================================================

# ─── Paiement Stripe ────────────────────────────────────────
# Clé secrète Stripe. sk_live_... en prod, sk_test_... en dev. REQUIS en prod (sinon mode démo).
STRIPE_SECRET_KEY=sk_test_REMPLACER
# Secret de signature des webhooks Stripe (whsec_...). REQUIS en prod (sinon webhooks rejetés).
STRIPE_WEBHOOK_SECRET=whsec_REMPLACER
# Clé publique Stripe (pk_live_...). Côté front. Optionnel (serveur démarre sans).
STRIPE_PUBLISHABLE_KEY=pk_test_REMPLACER
# Compte Stripe Connect (optionnel).
# STRIPE_ACCOUNT_ID=acct_REMPLACER

# ─── LLM ────────────────────────────────────────────────────
# Clé API Anthropic (sk-ant-...). REQUIS en prod (sinon fallback keyword, qualité dégradée).
ANTHROPIC_API_KEY=sk-ant-REMPLACER
# Modèle Anthropic pour la traduction i18n. Défaut : claude-haiku-4-5-20251001
# ANTHROPIC_TRANSLATION_MODEL=claude-haiku-4-5-20251001
# DeepL pour la traduction (prioritaire sur Anthropic si présent). Optionnel.
# DEEPL_API_KEY=REMPLACER
# Mistral pour l'OCR de documents. Optionnel.
# MISTRAL_API_KEY=REMPLACER
# OpenAI (pipeline-v3 uniquement, non critique). Optionnel.
# OPENAI_API_KEY=sk-REMPLACER

# ─── Sécurité ───────────────────────────────────────────────
# Token Bearer pour /api/admin/* (valeur libre secrète). REQUIS en prod (sinon admin = 403).
ADMIN_TOKEN=REMPLACER_token_admin_secret
# Salt HMAC pour hasher les emails citoyens (≥32 chars). REQUIS en prod (throw au boot sinon).
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CITIZEN_EMAIL_SALT=REMPLACER_salt_hex_64_chars
# Salt pour hasher les case_id (outcomes-tracker). ≥32 chars. REQUIS en prod (throw sinon).
OUTCOMES_HASH_SALT=REMPLACER_salt_hex_64_chars
# Clé AES-256 (hex 64 chars) pour chiffrer les emails au repos. Optionnel.
# CITIZEN_EMAIL_ENC_KEY=REMPLACER_hex_64_chars

# ─── Email (Resend) ─────────────────────────────────────────
# Clé API Resend pour les magic links d'auth. REQUIS en prod.
RESEND_API_KEY=re_REMPLACER
# Adresse d'expéditeur. Défaut : JusticePourtous <noreply@justicepourtous.ch>
# FROM_EMAIL=JusticePourtous <noreply@justicepourtous.ch>

# ─── Infra ──────────────────────────────────────────────────
# Port HTTP. Défaut : 3000 (docker-compose mappe 3001->3000 côté hôte).
# PORT=3000
# URL publique (success_url Stripe). Défaut : https://justicepourtous.ch
# SITE_URL=https://justicepourtous.ch
# Environnement. Mettre "production" en prod.
NODE_ENV=production
# Logs : niveau (debug|info|warn|error|silent, défaut info) et format (json|pretty, défaut json).
# LOG_LEVEL=info
# LOG_FORMAT=json

# ─── Sources jurisprudence externe (optionnel, défaut mock) ──
# OPENCASELAW_URL=https://api.opencaselaw.ch
# OPENCASELAW_MODE=mock
# ENTSCHEIDSUCHE_URL=https://entscheidsuche.ch/_search
# ENTSCHEIDSUCHE_MODE=mock

# ─── Dev / CI uniquement (NE PAS mettre en prod) ────────────
# LLM_MOCK=1            # mock LLM déterministe (tests sans vraie clé)
# ADMIN_TEST_SESSION=dev-session-test

# ─── COUPE-CIRCUIT JURIDIQUE ────────────────────────────────────────────────
# LEGAL_SAFE_MODE=1 (DÉFAUT, même si la variable est absente) : le triage
# personnalisé, la génération de lettres et le paiement sont NEUTRALISÉS. Le site
# informe et oriente vers des permanences, mais n'affirme plus aucun délai ni acte.
# La détection de détresse (violence, suicide) reste TOUJOURS active.
#
# Mis en place le 2026-07-11 après un audit : le contenu juridique (314 fiches
# écrites ET « relues » par un LLM, zéro relecture humaine) contenait des délais
# inexistants et une voie de recours qui n'existe pas en AI — servis sous un badge
# « articles et délais relus ».
#
# NE PASSER À 0 QU'UNE FOIS LE CONTENU VALIDÉ PAR UN JURISTE HUMAIN.
LEGAL_SAFE_MODE=1
