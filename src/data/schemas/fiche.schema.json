{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://justicepourtous.ch/schemas/fiche.schema.json",
  "title": "JusticePourtous — Fiche juridique",
  "description": "Schéma canonique d'une fiche de triage juridique citoyen. 264 fiches actives au 2026-04-18, 13 domaines.",
  "type": "object",
  "required": [
    "id",
    "domaine",
    "sousDomaine",
    "tags",
    "confiance",
    "questions",
    "reponse",
    "last_verified_at",
    "review_scope",
    "review_expiry"
  ],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]+$",
      "description": "Identifiant snake_case unique (ex. bail_defaut_moisissure)"
    },
    "domaine": {
      "type": "string",
      "enum": [
        "bail",
        "travail",
        "famille",
        "dettes",
        "etrangers",
        "assurances",
        "social",
        "violence",
        "accident",
        "entreprise",
        "circulation",
        "consommation",
        "voisinage",
        "successions",
        "sante"
      ],
      "description": "Un des 15 domaines connus de JusticePourtous"
    },
    "sousDomaine": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "confiance": {
      "type": "string",
      "enum": ["certain", "probable", "variable", "incertain"],
      "description": "Niveau de confiance global de la fiche"
    },
    "questions": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "options": {
            "type": "array",
            "items": { "type": "string" }
          },
          "type": { "type": "string" }
        },
        "anyOf": [
          { "required": ["options"] },
          { "required": ["type"] }
        ]
      }
    },
    "reponse": {
      "type": "object",
      "required": ["explication", "articles"],
      "properties": {
        "explication": {
          "type": "string",
          "minLength": 200,
          "description": "Texte juridique synthétique, jamais généré par LLM, toujours issu de la base"
        },
        "articles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["ref"],
            "properties": {
              "ref": { "type": "string", "minLength": 1 },
              "titre": { "type": "string" },
              "lien": { "type": "string" }
            }
          }
        },
        "jurisprudence": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "object",
            "required": ["ref"],
            "properties": {
              "ref": { "type": "string" },
              "resume": { "type": "string" }
            }
          }
        },
        "modeleLettre": { "type": "string" },
        "services": { "type": "array" },
        "routageEcosysteme": { "type": "object" },
        "disclaimer": { "type": "string" }
      }
    },
    "last_verified_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}(T.*)?$",
      "description": "Date ISO (YYYY-MM-DD ou ISO8601 complet) de dernière vérification"
    },
    "review_scope": {
      "type": "string",
      "enum": ["draft_automated", "reviewed_by_claude", "reviewed_by_legal_expert"]
    },
    "review_expiry": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}(T.*)?$"
    },
    "cascades": { "type": "array" },
    "anti_erreurs": { "type": "array" },
    "patterns": { "type": "array" },
    "templates": { "type": "array" },
    "escalade": { "type": "object" },
    "delais": { "type": "array" },
    "services": { "type": "array" },
    "modeleLettre": { "type": "string" },
    "match_description": { "type": "string" },
    "profane_aliases": { "type": "array", "items": { "type": "string" } },
    "negative_signals": { "type": "array", "items": { "type": "string" } },
    "required_facts": { "type": "array", "items": { "type": "string" } },
    "maj": { "type": "string" },
    "sourceLoi": { "type": "string" },
    "dateVerification": { "type": "string" },
    "verificationOk": { "type": "boolean" }
  },
  "x-warnings": {
    "description": "Règles non bloquantes appliquées par fiche-validator.mjs",
    "rules": [
      "confiance=certain doit être associé à review_scope=reviewed_by_legal_expert",
      "review_expiry doit être postérieur à last_verified_at",
      "explication courte (<400 chars) recommande au moins 2 articles",
      "fiche sans cascades ni modeleLettre → triage non actionnable"
    ]
  }
}
